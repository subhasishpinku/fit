<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base configuration for all connections -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    
    <!-- Domain specific configurations -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">aipoweredfitness.com</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">vimeo.com</domain>
        <domain includeSubdomains="true">player.vimeo.com</domain>
        <domain includeSubdomains="true">i.vimeocdn.com</domain>
        <domain includeSubdomains="true">f.vimeocdn.com</domain>
        <domain includeSubdomains="true">vod-progressive.akamaized.net</domain>
    </domain-config>
    
    <!-- Debug overrides for development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>